---
layout: project_views
---

{% if page.date %}
  <p class="podcast-episode-date">{{ page.date | date: "%B %-d, %Y" }}</p>
{% endif %}

<div class="podcast-episode-video">
  <iframe
    src="https://www.youtube-nocookie.com/embed/{{ page.youtube }}?rel=0"
    title="{{ page.title | escape }}"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>

{% if page.description %}
  <p class="podcast-episode-desc">{{ page.description }}</p>
{% endif %}

{{ content }}

<p class="podcast-episode-back">
  <a href="{{ '/podcast/' | relative_url }}">← Back to all episodes</a>
</p>

<style>
  .podcast-episode-date {
    font-size: 0.9rem;
    opacity: 0.7;
    margin: 0 0 1rem;
  }
  .podcast-episode-video {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 0 0 1.25rem;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
  }
  .podcast-episode-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .podcast-episode-desc {
    font-size: 1.05rem;
    max-width: 46rem;
  }
  .podcast-episode-back {
    margin-top: 2rem;
  }
</style>
